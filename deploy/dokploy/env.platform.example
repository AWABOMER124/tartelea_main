# Dokploy Platform Environment (EXAMPLE)
#
# Copy values into Dokploy "Environment Variables / Secrets".
# Do not commit real values. This file is a placeholder for naming and wiring.

# Public domains
PUBLIC_WEB_HOST=tartelea.example.com
PUBLIC_DIRECTUS_HOST=cms.tartelea.example.com
PUBLIC_LIVEKIT_HOST=livekit.tartelea.example.com
TRAEFIK_NETWORK=traefik

# PostgreSQL (single source of truth)
DB_NAME=tartelea_db
DB_USER=tartelea
DB_PASSWORD=change_me

# Backend core
JWT_SECRET=change_me
ALLOWED_ORIGINS=https://tartelea.example.com

# Optional auth integrations
GOOGLE_CLIENT_ID=

# Mail (optional)
EMAIL_ENABLED=false
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
REQUIRE_EMAIL_VERIFICATION=false
AUTO_VERIFY_EMAIL=true
OTP_DEV_FALLBACK=true

# LiveKit (backend token minting must match LiveKit server config)
LIVEKIT_API_KEY=change_me
LIVEKIT_API_SECRET=change_me

# Directus (backend calls CMS through gateway only)
DIRECTUS_URL=https://cms.tartelea.example.com
DIRECTUS_TOKEN=change_me
DIRECTUS_KEY=change_me
DIRECTUS_SECRET=change_me
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change_me

# Valkey / Redis (recommended for Directus cache)
VALKEY_PASSWORD=change_me

# MinIO (recommended for Directus media)
MINIO_ROOT_USER=change_me
MINIO_ROOT_PASSWORD=change_me
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=directus
