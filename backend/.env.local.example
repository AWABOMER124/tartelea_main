NODE_ENV=development
PORT=3000

# Copy this file to backend/.env.local when you want local-only overrides.
# Values in .env.local are loaded after backend/.env and take precedence.

# Host-machine PostgreSQL:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tartelea-db
DB_USER=tartelea
DB_PASSWORD=change_me

# Managed PostgreSQL example:
# DATABASE_URL=postgres://user:password@host:5432/database

JWT_SECRET=change_me
ALLOWED_ORIGINS=*

EMAIL_ENABLED=false
REQUIRE_EMAIL_VERIFICATION=false
AUTO_VERIFY_EMAIL=true
OTP_DEV_FALLBACK=true
SUBSCRIPTIONS_PAUSED=false
TRAINER_EMAILS=
