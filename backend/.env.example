NODE_ENV=development
PORT=3000

# Copy to backend/.env (DO NOT COMMIT backend/.env)
# Optional: create backend/.env.local for machine-specific overrides.
#
# You can configure PostgreSQL using either:
# - DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD
# - or DATABASE_URL=postgres://user:password@host:5432/database

# Host-machine PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tartelea-db
DB_USER=tartelea
DB_PASSWORD=change_me

# Managed DB example (preferred when available)
# DATABASE_URL=postgres://user:password@host:5432/database
# DATABASE_SSL=true

JWT_SECRET=change_me
# CORS allowlist
# - Development can use "*"
# - Production should be an explicit comma-separated allowlist, e.g.
#   ALLOWED_ORIGINS=https://tartelea.com,https://www.tartelea.com,https://admin.tartelea.com
ALLOWED_ORIGINS=*

# Feature flags
EMAIL_ENABLED=false
REQUIRE_EMAIL_VERIFICATION=false
AUTO_VERIFY_EMAIL=true
OTP_DEV_FALLBACK=true
SUBSCRIPTIONS_PAUSED=false
TRAINER_EMAILS=

# SMTP (optional)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=

# Social login (optional)
GOOGLE_CLIENT_ID=

# LiveKit server credentials (optional, required for token minting)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Public LiveKit WebSocket URL returned to clients
LIVEKIT_URL=wss://rtc.tartelea.com

# Directus (CMS) integration (optional)
DIRECTUS_URL=
DIRECTUS_TOKEN=

# Optional integrations
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET_KEY=
LOVABLE_API_KEY=
