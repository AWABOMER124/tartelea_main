# Server Configuration
NODE_ENV=development
PORT=3000
JWT_SECRET=your_jwt_secret_key_here
ALLOWED_ORIGINS=*

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tartelea-db
DB_USER=tartelea
DB_PASSWORD=change_me
# DATABASE_URL=postgresql://user:password@host:port/tartelea-db

# Email / OTP Delivery
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_email_username
EMAIL_PASS=your_email_password
EMAIL_ENABLED=false
REQUIRE_EMAIL_VERIFICATION=false
AUTO_VERIFY_EMAIL=true
OTP_DEV_FALLBACK=true
# Verification and password reset rely on a reachable SMTP server unless bypass flags are enabled.

# OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here

# LiveKit Configuration (Audio Rooms)
LIVEKIT_URL=wss://your-livekit-server-url
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Production Flags
DEBUG_LOGGING=false
ENABLE_WEBHOOKS=true

